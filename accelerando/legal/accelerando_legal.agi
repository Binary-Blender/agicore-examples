ACTION AnalyzeCommunicationRisk {
  INPUT  flag_ids: string, time_period_days: number
  OUTPUT risk_summary: string, risk_score_delta: float
  AI     "Review the provided legal hygiene flags from the past [time_period_days] days. For each flag type, assess: (1) what specific legal risk the flagged language creates, (2) how this pattern compounds with other flags detected, (3) whether this represents isolated incidents or systemic behavior. Provide: a risk score delta recommendation, a one-paragraph plain-English risk summary, and three specific behavioral recommendations the organization can act on immediately. Be direct. These are real documents that could appear in discovery."
}

ACTION GenerateLegalRiskReport {
  INPUT  matter_ids: string, time_period_days: number
  OUTPUT report: string
  AI     "Generate a weekly legal risk advisory memo. Review active legal matters, open hygiene flags, and pattern trends. Structure: (1) Executive Summary — 3 bullet points, most important things to know this week, (2) Active Matter Status — brief status per open matter, flag any deadline or production risks, (3) Hygiene Alert Summary — grouped by flag type, pattern across the organization, (4) Recommended Actions — numbered list, most urgent first. Tone: direct, non-alarmist, like a trusted outside counsel giving a weekly briefing. Not a lawyer. A very well-organized advisor who has seen how these patterns end."
}

ACTION GenerateHoldNotice {
  INPUT  hold_id: string, custodian_id: string
  OUTPUT notice_text: string
  AI     "Generate a legal hold notice for the specified custodian. Include: the matter description (without disclosing attorney work product), the scope of preserved data (email, files, Slack, etc.), the date range covered, specific instructions for preserving data and ceasing deletion, the process for acknowledging receipt, and who to contact with questions. Tone: formal, clear, not threatening. The recipient is an employee who may be nervous — make the notice professional and procedurally clear."
}

ACTION LogLegalEvent {
  INPUT  event_type: string, matter_id: string, detail: string
  OUTPUT logged: bool
  IMPL {
    // Append to legal event log with timestamp, user, event_type, matter_id, detail
    // Legal event log is immutable — append only, no updates
    // This is the chain of custody record
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOWS
// ─────────────────────────────────────────────────────────────────────────────

WORKFLOW trigger_legal_hold {
  IDEMPOTENT false
  STEP assess             { ACTION AssessLegalHoldRequirements  ON_FAIL abort }
  STEP trigger            { ACTION TriggerLegalHold             ON_FAIL abort }
  STEP notify             { ACTION NotifyCustodians             ON_FAIL abort }
  STEP sync_connectors    { ACTION SyncAllConnectors            ON_FAIL skip  }
  STEP preserve           { ACTION PreserveCustodianData        ON_FAIL skip  }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW collect_and_process {
  IDEMPOTENT true
  STEP sync               { ACTION SyncAllConnectors            ON_FAIL abort }
  STEP collect            { ACTION CollectDocuments             ON_FAIL abort }
  STEP assign             { ACTION AssignDocumentsForReview     ON_FAIL skip  }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW privilege_review_and_production {
  IDEMPOTENT false
  STEP privilege_log      { ACTION GeneratePrivilegeLog         ON_FAIL abort }
  STEP apply_bates        { ACTION ApplyBatesNumbers            ON_FAIL abort }
  STEP produce            { ACTION ProduceDocuments             ON_FAIL abort }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW release_hold {
  IDEMPOTENT false
  STEP release            { ACTION ReleaseHold                  ON_FAIL abort }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW legal_hygiene_scan {
  IDEMPOTENT true
  STEP scan_exchange      { ACTION SyncExchangeMailbox          ON_FAIL skip  }
  STEP scan_gmail         { ACTION SyncGmailMailbox             ON_FAIL skip  }
  STEP scan_slack         { ACTION SyncSlackChannel             ON_FAIL skip  }
  STEP scan_onedrive      { ACTION SyncOneDrive                 ON_FAIL skip  }
  STEP scan_gdrive        { ACTION SyncGoogleDrive              ON_FAIL skip  }
  STEP analyze_flags      { ACTION AnalyzeCommunicationRisk     ON_FAIL skip  }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW weekly_legal_risk_assessment {
  IDEMPOTENT true
  STEP scan_hygiene       { ACTION ScanCommunicationChannel     ON_FAIL skip  }
  STEP analyze            { ACTION AnalyzeCommunicationRisk     ON_FAIL skip  }
  STEP generate_report    { ACTION GenerateLegalRiskReport      ON_FAIL skip  }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

WORKFLOW onboard_connector {
  IDEMPOTENT false
  STEP configure          { ACTION LogLegalEvent                ON_FAIL abort }
  STEP test_connection    { ACTION SyncAllConnectors            ON_FAIL abort }
  STEP initial_sync       { ACTION SyncAllConnectors            ON_FAIL skip  }
  STEP log                { ACTION LogLegalEvent                ON_FAIL skip  }
}

// ─────────────────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────────────────

VIEW LegalMatterDashboard {
  ENTITY   LegalMatter
  LAYOUT   table
  ACTIONS  create, edit
}

VIEW HoldManagement {
  ENTITY   LegalHold
  LAYOUT   table
  ACTIONS  create, edit
}

VIEW DocumentReview {
  ENTITY   ReviewDocument
  LAYOUT   table
  ACTIONS  edit
}

VIEW LegalHygieneMonitor {
  ENTITY   LegalHygieneFlag
  LAYOUT   table
  ACTIONS  edit
}

VIEW ConnectorStatus {
  ENTITY   ExternalConnector
  LAYOUT   table
  ACTIONS  create, edit
}

VIEW ProductionManager {
  ENTITY   ProductionSet
  LAYOUT   table
  ACTIONS  create, edit
}

VIEW RetentionPolicies {
  ENTITY   RetentionPolicy
  LAYOUT   table
  ACTIONS  create, edit
}

// ─────────────────────────────────────────────────────────────────────────────
// PREFERENCES
// ─────────────────────────────────────────────────────────────────────────────

PREFERENCE hygiene_scan_interval_hours       { DEFAULT 24    TYPE number }
PREFERENCE production_deadline_warning_days  { DEFAULT 14    TYPE number }
PREFERENCE connector_sync_stale_hours        { DEFAULT 24    TYPE number }
PREFERENCE legal_risk_notify_threshold       { DEFAULT 50    TYPE number }
PREFERENCE hold_ack_deadline_hours           { DEFAULT 48    TYPE number }
PREFERENCE retention_expiry_warning_days     { DEFAULT 30    TYPE number }

// ─────────────────────────────────────────────────────────────────────────────
// SEED DATA — Default Retention Policies
// ─────────────────────────────────────────────────────────────────────────────

SEED RetentionPolicy [
  { policy_name: "Email Correspondence",       document_category: "email",      retention_years: 7,  legal_basis: "general_business",    deletion_method: "secure_delete" },
  { policy_name: "Contracts and Agreements",   document_category: "contracts",  retention_years: 10, legal_basis: "statute_of_limitations", deletion_method: "secure_delete" },
  { policy_name: "Financial Records",          document_category: "financial",  retention_years: 7,  legal_basis: "IRS",                 deletion_method: "secure_delete" },
  { policy_name: "HR and Personnel",           document_category: "hr",         retention_years: 7,  legal_basis: "EEOC",                deletion_method: "secure_delete" },
  { policy_name: "Compliance Documentation",   document_category: "compliance", retention_years: 10, legal_basis: "regulatory",          deletion_method: "secure_delete" },
  { policy_name: "General Business Records",   document_category: "general",    retention_years: 5,  legal_basis: "internal",            deletion_method: "secure_delete" }
]
