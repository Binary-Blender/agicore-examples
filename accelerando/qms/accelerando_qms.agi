    // Assign to area owner
    // Notify owner and QMS manager
    // If source is recurring NCR: set CAPAContext.systemic_issue_detected = true
  }
}

ACTION ReferToPICoE {
  INPUT  capa_id: string, ncr_id: string
  OUTPUT referral_sent: bool
  IMPL {
    // Build CAPAToPICoEPacket with problem description and root cause
    // Count recurrence: how many times has this root cause appeared in last 12 months
    // If recurrence_count >= 2: systemic issue, Kaizen event recommended
    // Emit to capa_to_pi_coe CHANNEL
    // Set NonConformance.pi_coe_referral = true
    // Log referral in QMS event log
  }
}

ACTION VerifyCAPAEffectiveness {
  INPUT  capa_id: string, verifier_id: string
  OUTPUT effective: bool, verification_notes: string
  IMPL {
    // Load CAPA and linked NCR/finding/complaint
    // Check: has the original nonconformance recurred since CAPA implementation?
    // Check: are the control measures from the CAPA still in place?
    // Check: have new NCRs with same root cause appeared since closure?
    // If all checks pass: effective = true, status = "closed", recurrence_prevented = true
    // If any check fails: effective = false, status = "ineffective"
