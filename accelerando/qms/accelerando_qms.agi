    //   Trigger new CAPA with reference to failed one
  }
}

ACTION GenerateNCRReport {
  INPUT  ncr_id: string
  OUTPUT report_text: string
  AI     "Generate a formal nonconformance report for the specified NCR. Include: (1) NCR identification number, date, area, severity, (2) Description of the nonconformance — what was found, where, when, by whom, how much affected, (3) Objective evidence — the specific observations, measurements, or documents that confirm the nonconformance, (4) Immediate containment action — what was done immediately to prevent nonconforming product from reaching the next step or the customer, (5) Disposition — use as-is, rework, scrap, return to supplier (with justification), (6) Root cause analysis — using the stated method (5-Why, Ishikawa, etc.) — include the full logic chain, not just the conclusion, (7) Corrective action required — yes/no, and if yes, what is the scope, (8) Signature blocks for: originator, QA review, area manager approval. ISO 9001 Clause 8.7 requires this record be maintained."
}

ACTION GenerateAuditReport {
  INPUT  audit_id: string
  OUTPUT report_text: string
  AI     "Generate an internal audit report for the specified audit. Structure per ISO 19011: (1) Audit summary — scope, criteria (ISO 9001:2015 clauses audited), dates, team, (2) Methodology — document review, process observation, interviews; sampling rationale, (3) Findings — each finding with: finding number, type (major/minor/observation), clause reference, description, objective evidence (specific documents, records, or observations cited), (4) Positive observations — what is working well; audit reports that only record deficiencies miss the opportunity to acknowledge effective practices, (5) Summary and Conclusion — overall assessment of conformance for the audited clauses and areas, (6) Required actions — major NCs require CAPA within [preference] days; minor NCs require corrective action; observations require management awareness. The audit report is a legal record. It must be specific, objective, and evidence-based. 'Not doing X' is not a finding. 'Record 12345 does not contain required field Y, per procedure QP-003 Rev 4 Clause 4.2' is a finding."
}

ACTION ScheduleInternalAuditProgram {
  INPUT  year: number, clauses_to_cover: string
  OUTPUT audit_schedule: string
  AI     "Generate an annual internal audit schedule that satisfies ISO 9001 Clause 9.2 requirements. Requirements: (1) all clauses of ISO 9001:2015 must be audited at least once per year (all 10 clause groups), (2) high-risk areas and processes with prior major findings must be audited more frequently, (3) auditors must be independent of the area being audited, (4) schedule must be approved by QMS management, (5) distribute evenly across the year — avoid clustering audits in the month before an external audit. For each scheduled audit: clause references, area to audit, suggested auditor (noting independence requirements), suggested duration, risk rationale for scheduling. Flag any clause coverage gaps. Output as a formatted audit schedule table suitable for management approval."
}

ACTION AssessAuditReadiness {
  INPUT  audit_type: string
  OUTPUT readiness_score: float, readiness_report: string
  IMPL {
    // Count open CAPAs and overdue CAPAs
    // Count open NCRs by severity
    // Check management review is current (within 12 months)
    // Check all documents reviewed on schedule
    // Count calibration overdue equipment
    // Check all ISO 9001 clauses covered in audit program this year
    // Calculate readiness_score (0-100):
    //   No open major CAPAs: +20
    //   No overdue CAPAs: +15
    //   Management review current: +15
    //   Document control current: +15
    //   Calibration current: +10
    //   Full clause coverage: +15
    //   No critical NCRs open: +10
    // Emit AuditReadinessPacket
    // Return plain-English readiness report
  }
}

ACTION GenerateManagementReviewPackage {
  INPUT  review_id: string
  OUTPUT package_text: string
  AI     "Generate a management review input package for ISO 9001 Clause 9.3.2. Required inputs (all must be addressed): (1) Status of actions from previous reviews, (2) Changes in external and internal issues relevant to the QMS, (3) Information on QMS performance including: customer satisfaction and feedback, quality objectives achievement, process performance and conformity, nonconformances and corrective actions, monitoring and measurement results, audit results, supplier performance, (4) Adequacy of resources, (5) Effectiveness of actions to address risks and opportunities, (6) Opportunities for improvement. For each input area: provide the current data summary, trend (improving/stable/declining), and flag any areas requiring a management decision or resource allocation. The output of the review (Clause 9.3.3) must include: decisions on improvement opportunities, changes to QMS, resource needs. Draft the output decisions based on the input analysis. Make explicit recommendations — management review that doesn't produce decisions is a compliance exercise, not a management tool."
}

ACTION LogQMSEvent {
  INPUT  event_type: string, entity_id: string, detail: string
  OUTPUT logged: bool
  IMPL {
    // Append-only QMS event log
    // Records: NCR creation, CAPA initiation, audit findings, effectiveness checks,
    //   management reviews, document approvals, calibration records
    // Each entry: timestamp, user, event_type, entity_id, detail, hash of prior entry
    // This is the ISO 9001 documented information requirement (Clause 7.5)
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOWS
// ─────────────────────────────────────────────────────────────────────────────

WORKFLOW ncr_to_capa {
  IDEMPOTENT false
  STEP create_ncr         { ACTION GenerateNCRReport             ON_FAIL abort }
  STEP containment        { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP root_cause         { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP initiate_capa      { ACTION InitiateCorrectiveAction      ON_FAIL abort }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW capa_effectiveness_check {
  IDEMPOTENT false
  STEP verify             { ACTION VerifyCAPAEffectiveness       ON_FAIL abort }
  STEP refer_if_systemic  { ACTION ReferToPICoE                  ON_FAIL skip  }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW internal_audit {
  IDEMPOTENT false
  STEP readiness_check    { ACTION AssessAuditReadiness          ON_FAIL skip  }
  STEP conduct_audit      { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP generate_report    { ACTION GenerateAuditReport           ON_FAIL abort }
  STEP issue_findings     { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP initiate_capas     { ACTION InitiateCorrectiveAction      ON_FAIL skip  }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW management_review {
  IDEMPOTENT false
  STEP generate_package   { ACTION GenerateManagementReviewPackage ON_FAIL abort }
  STEP conduct_review     { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP capture_outputs    { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP assign_actions     { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW handle_customer_complaint {
  IDEMPOTENT false
  STEP acknowledge        { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP create_ncr         { ACTION GenerateNCRReport             ON_FAIL skip  }
  STEP root_cause         { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP initiate_capa      { ACTION InitiateCorrectiveAction      ON_FAIL skip  }
  STEP respond_customer   { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP close_complaint    { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW annual_audit_planning {
  IDEMPOTENT false
  STEP schedule           { ACTION ScheduleInternalAuditProgram  ON_FAIL abort }
  STEP approve            { ACTION LogQMSEvent                   ON_FAIL abort }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

WORKFLOW pre_audit_readiness {
  IDEMPOTENT true
  STEP assess             { ACTION AssessAuditReadiness          ON_FAIL abort }
  STEP close_capas        { ACTION LogQMSEvent                   ON_FAIL skip  }
  STEP document_review    { ACTION LogQMSEvent                   ON_FAIL skip  }
  STEP log                { ACTION LogQMSEvent                   ON_FAIL skip  }
}

// ─────────────────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────────────────

VIEW QMSDashboard {
  ENTITY   QualityObjective
  LAYOUT   table
  ACTIONS  read
}

VIEW NCRRegister {
  ENTITY   NonConformance
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW CAPARegister {
  ENTITY   CorrectiveAction
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW AuditCalendar {
  ENTITY   InternalAudit
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW DocumentRegister {
  ENTITY   QMSDocument
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW ComplaintRegister {
  ENTITY   CustomerComplaint
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW SupplierRegister {
  ENTITY   SupplierAssessment
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW CalibrationDue {
  ENTITY   CalibrationRecord
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW RiskRegister {
  ENTITY   RiskOpportunity
  LAYOUT   table
  ACTIONS  create, read, edit
}

// ─────────────────────────────────────────────────────────────────────────────
// PREFERENCES
// ─────────────────────────────────────────────────────────────────────────────

PREFERENCE capa_default_days                    { DEFAULT 30   TYPE number }
PREFERENCE effectiveness_check_days             { DEFAULT 90   TYPE number }
PREFERENCE complaint_ack_target_hours           { DEFAULT 24   TYPE number }
PREFERENCE complaint_resolution_target_days     { DEFAULT 30   TYPE number }
PREFERENCE management_review_frequency_days     { DEFAULT 365  TYPE number }
PREFERENCE audit_finding_response_days          { DEFAULT 10   TYPE number }
PREFERENCE supplier_assessment_frequency_days   { DEFAULT 365  TYPE number }
PREFERENCE document_review_frequency_days       { DEFAULT 365  TYPE number }
PREFERENCE capa_to_pi_coe_recurrence_threshold  { DEFAULT 2    TYPE number }
PREFERENCE calibration_warning_days             { DEFAULT 30   TYPE number }

