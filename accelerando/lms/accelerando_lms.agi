ACTION ExportComplianceAuditRecord {
  INPUT  tenant_id: string, domain_id: string, as_of_date: date
  OUTPUT export_url: string
  IMPL {
    // Generate point-in-time compliance snapshot:
    //   Per employee: score per domain, status, last assessed, refresher history
    //   Per department: compliance rate per domain
    //   Org-wide: overall compliance rate
    // Include assessment response log for the period
    // Include all manager notifications sent
    // Format: CSV + PDF summary (machine-readable + human-readable)
    // Chain of custody: timestamp, generated_by, audit_hash
    // This is what you hand to the regulator. It proves knowledge, not attendance.
  }
}

ACTION SendDailyAssessmentReminder {
  INPUT  learner_id: string, streak_days: number
  OUTPUT sent: bool
  IMPL {
    // Calculate streak message:
    //   streak_days == 0: "Start your streak today"
    //   streak_days < 7: "[N]-day streak! Keep it going"
    //   streak_days >= 7: "[N]-day streak! You're on fire"
    // Send notification (email / in-app / push based on preference)
    // Include estimated time: "3 questions · ~60 seconds"
    // Deep link directly to today's assessment — minimize friction
  }
}

ACTION GenerateWeeklySummary {
  INPUT  tenant_id: string
  OUTPUT report_id: string
  AI     "Generate a weekly compliance training summary for leadership. Include: (1) org-wide compliance rate vs last week (trending direction matters more than absolute number), (2) top 3 departments by compliance rate and bottom 3 — call out dramatic changes in either direction, (3) domains where org-wide scores dropped this week — if multiple people failed the same topic, the topic may need better content, not just more reminders, (4) streak leaders — the social proof that the habit is spreading, (5) refreshers assigned vs completed this week — completion rate is the health metric for the refresher system itself. Tone: brief, data-forward, one page maximum. This goes to the Chief Compliance Officer on Monday morning."
}

ACTION GenerateRegulatoryComplianceReport {
  INPUT  tenant_id: string, regulatory_framework: string, period_start: date, period_end: date
  OUTPUT report_id: string
  AI     "Generate a regulatory compliance training report for [regulatory_framework] for the period [period_start] to [period_end]. Structure: (1) Executive Summary — one paragraph, overall compliance posture, (2) Methodology — explain that this system uses daily micro-assessment and continuous knowledge scoring rather than annual completion records, and why this provides stronger evidence of actual compliance, (3) Domain Coverage — which domains map to which regulatory requirements, (4) Compliance Statistics — employee count, compliant/at-risk/non-compliant counts per domain, average knowledge scores, (5) Remediation Actions — refreshers assigned and completed, manager notifications issued, (6) Audit Trail Statement — all records available for regulatory inspection with timestamps and hash verification. Format for regulatory submission."
}

ACTION LogTrainingEvent {
  INPUT  event_type: string, learner_id: string, detail: string
  OUTPUT logged: bool
  IMPL {
    // Append-only training event log
    // Records: assessment completions, refresher assignments, badge awards,
    //   manager notifications, score threshold crossings, streak events
    // Immutable: this is the audit trail
    // Each entry: timestamp, learner_id, event_type, detail, hash of prior entry
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOWS
// ─────────────────────────────────────────────────────────────────────────────

WORKFLOW daily_assessment_cycle {
  IDEMPOTENT true
  STEP select_questions    { ACTION SelectDailyQuestions            ON_FAIL abort }
  STEP serve_questions     { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP score               { ACTION ScoreAssessment                 ON_FAIL abort }
  STEP update_knowledge    { ACTION UpdateKnowledgeProfile          ON_FAIL abort }
  STEP update_streak       { ACTION UpdateStreak                    ON_FAIL skip  }
  STEP check_refresher     { ACTION AssignRefresher                 ON_FAIL skip  }
  STEP gamification        { ACTION AwardBadge                      ON_FAIL skip  }
  STEP log                 { ACTION LogTrainingEvent                ON_FAIL skip  }
}

WORKFLOW onboard_new_employee {
  IDEMPOTENT false
  STEP create_profile      { ACTION LogTrainingEvent                ON_FAIL abort }
  STEP assign_domains      { ACTION LogTrainingEvent                ON_FAIL abort }
  STEP initial_assessment  { ACTION SelectDailyQuestions            ON_FAIL skip  }
  STEP notify_employee     { ACTION SendDailyAssessmentReminder     ON_FAIL skip  }
  STEP log                 { ACTION LogTrainingEvent                ON_FAIL skip  }
}

WORKFLOW refresher_completion {
  IDEMPOTENT false
  STEP mark_complete       { ACTION LogTrainingEvent                ON_FAIL abort }
  STEP update_knowledge    { ACTION UpdateKnowledgeProfile          ON_FAIL abort }
  STEP recalculate_dept    { ACTION CalculateDepartmentCompliance   ON_FAIL skip  }
  STEP log                 { ACTION LogTrainingEvent                ON_FAIL skip  }
}

WORKFLOW daily_reminders {
  IDEMPOTENT true
  STEP identify_pending    { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP send_reminders      { ACTION SendDailyAssessmentReminder     ON_FAIL skip  }
  STEP mark_expired        { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP update_streaks      { ACTION UpdateStreak                    ON_FAIL skip  }
}

WORKFLOW weekly_compliance_rollup {
  IDEMPOTENT true
  STEP calculate_dept      { ACTION CalculateDepartmentCompliance   ON_FAIL abort }
  STEP check_refreshers    { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP generate_summary    { ACTION GenerateWeeklySummary           ON_FAIL skip  }
  STEP ai_intelligence     { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP log                 { ACTION LogTrainingEvent                ON_FAIL skip  }
}

WORKFLOW generate_curriculum {
  IDEMPOTENT false
  STEP generate_questions  { ACTION GenerateQuestions               ON_FAIL abort }
  STEP generate_modules    { ACTION GenerateTrainingModule          ON_FAIL skip  }
  STEP validate_bank       { ACTION LogTrainingEvent                ON_FAIL skip  }
  STEP publish             { ACTION LogTrainingEvent                ON_FAIL skip  }
}

WORKFLOW export_for_audit {
  IDEMPOTENT true
  STEP export_records      { ACTION ExportComplianceAuditRecord     ON_FAIL abort }
  STEP generate_report     { ACTION GenerateRegulatoryComplianceReport ON_FAIL skip }
  STEP log                 { ACTION LogTrainingEvent                ON_FAIL skip  }
}

// ─────────────────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────────────────

VIEW ComplianceDashboard {
  ENTITY   DepartmentCompliance
  LAYOUT   table
  ACTIONS  read
}

VIEW LearnerView {
  ENTITY   LearnerProfile
  LAYOUT   form
  ACTIONS  read, edit
}

VIEW DailyAssessmentView {
  ENTITY   DailyAssessment
  LAYOUT   form
  ACTIONS  create, read
}

VIEW ComplianceScoreView {
  ENTITY   ComplianceScore
  LAYOUT   table
  ACTIONS  read
}

VIEW RefresherQueue {
  ENTITY   RefresherAssignment
  LAYOUT   table
  ACTIONS  read, edit
}

VIEW QuestionBank {
  ENTITY   Question
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW BadgeGallery {
  ENTITY   ComplianceBadge
  LAYOUT   table
  ACTIONS  read
}

VIEW DomainManagement {
  ENTITY   ComplianceDomain
  LAYOUT   table
  ACTIONS  create, read, edit
}

// ─────────────────────────────────────────────────────────────────────────────
// PREFERENCES
// ─────────────────────────────────────────────────────────────────────────────

PREFERENCE daily_questions_per_learner          { DEFAULT 3    TYPE number }
PREFERENCE domain_passing_score                 { DEFAULT 75   TYPE number }
PREFERENCE domain_critical_score               { DEFAULT 60   TYPE number }
PREFERENCE refresher_deadline_days             { DEFAULT 7    TYPE number }
PREFERENCE streak_freeze_credits_max           { DEFAULT 2    TYPE number }
PREFERENCE assessment_window_start_hour        { DEFAULT 8    TYPE number }
PREFERENCE assessment_window_end_hour          { DEFAULT 18   TYPE number }
PREFERENCE reminder_advance_hours              { DEFAULT 2    TYPE number }
PREFERENCE knowledge_decay_alpha               { DEFAULT 0.15 TYPE number }
PREFERENCE min_questions_per_domain            { DEFAULT 30   TYPE number }

