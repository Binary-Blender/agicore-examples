// ═══════════════════════════════════════════════════════════════════════════════
// TESTS
// ═══════════════════════════════════════════════════════════════════════════════

TEST rule_firing_persistence {
  GIVEN RuleFiring {
    tenant_id:    "test"
    module_name:  "CreditControl"
    rule_name:    "block_new_orders"
    severity:     "critical"
    action_taken: "credit_block"
    entity_type:  "Customer"
    entity_id:    "customer-001"
    acknowledged: false
    fired_at:     "2026-05-20T00:00:00Z"
  }
  EXPECT create -> id IS NOT NULL
  EXPECT get_by_id -> module_name == "CreditControl"
  EXPECT get_by_id -> severity == "critical"
  EXPECT get_by_id -> acknowledged == false
}

TEST alert_acknowledgment {
  GIVEN RuleFiring {
    tenant_id:    "test"
    module_name:  "SLAEnforcement"
    rule_name:    "critical_unassigned"
    severity:     "critical"
    action_taken: "sla_breach_imminent_critical"
    entity_type:  "ServiceTicket"
    entity_id:    "ticket-001"
    acknowledged: false
    fired_at:     "2026-05-20T00:00:00Z"
  }
  EXPECT create -> id IS NOT NULL
  EXPECT get_by_id -> acknowledged == false
  EXPECT get_by_id -> rule_name == "critical_unassigned"
}

TEST fact_snapshot_capture {
  GIVEN FactSnapshot {
    tenant_id:    "test"
    module_name:  "InventoryControl"
    fact_name:    "StockLevel"
    entity_type:  "InventoryItem"
    entity_id:    "product-001"
    evaluated_at: "2026-05-20T00:00:00Z"
  }
  EXPECT create -> id IS NOT NULL
  EXPECT get_by_id -> fact_name == "StockLevel"
  EXPECT get_by_id -> module_name == "InventoryControl"
}
