// ─────────────────────────────────────────────────────────────────────────────
// TESTS
// ─────────────────────────────────────────────────────────────────────────────

TEST payer_contract_create {
  GIVEN   PayerContract { payer_id: "TEST-PAYER", payer_name: "Test Insurance", contract_version: "2026", effective_date: "2026-01-01", fee_schedule_id: "TEST-FS", tenant_id: "test" }
  EXPECT  create -> payer_id IS NOT NULL
  EXPECT  create -> active == true
  EXPECT  create -> timely_filing_days == 90
}

TEST claim_record_create {
  GIVEN   ClaimRecord { patient_id: "PAT-001", payer_id: "BCBS", claim_control: "CLM-TEST-001", service_date: "2026-05-20", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  create -> status == "draft"
  EXPECT  create -> denial_count == 0
}

TEST payer_rule_pending_review {
  GIVEN   PayerRule { payer_id: "BCBS", rule_name: "test_rule", rule_description: "Test", dsl_text: "WHEN ClaimContext.payer_id == \"BCBS\" THEN FLAG \"test\"", source: "ai_generated", tenant_id: "test" }
  EXPECT  create -> status == "pending_review"
  EXPECT  create -> active == false
}

TEST denial_record_create {
  GIVEN   DenialRecord { claim_id: "CLM-001", denial_group: "CO", reason_code: "CO-45", denial_description: "Contractual obligation", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  create -> status == "new"
}
