SEED PayerRule {
  payer_id:          "BCBS"
  rule_name:         "bcbs_modifier_25_same_day_em_procedure"
  rule_description:  "BCBS requires modifier 25 on E&M codes (99202-99215) when a procedure is performed the same day. Without it, BCBS bundles the E&M into the procedure and denies it. This rule was generated from 847 denials over 6 months."
  dsl_text:          "WHEN ClaimContext.has_same_day_procedure == true AND ClaimContext.has_modifier_25 == false AND ClaimContext.payer_id == \"BCBS\" THEN FLAG \"add_modifier_25_em_code\" SEVERITY critical PRIORITY 100"
  cpt_scope:         "99202,99203,99204,99205,99211,99212,99213,99214,99215"
  source:            "ai_generated"
  status:            "active"
  denial_count:      847
  confidence:        0.96
  active:            true
  tenant_id:         "acme"
}

SEED PayerRule {
  payer_id:          "MEDICARE"
  rule_name:         "medicare_cci_office_visit_bundled_with_injection"
  rule_description:  "CCI edit: Medicare bundles 99213 with J3301 (triamcinolone injection) when billed same day without modifier 25. Modifier 25 required to establish E&M was separately identifiable."
  dsl_text:          "WHEN ClaimContext.has_same_day_procedure == true AND ClaimContext.has_modifier_25 == false AND ClaimContext.payer_id == \"MEDICARE\" THEN FLAG \"add_modifier_25_em_code\" SEVERITY critical PRIORITY 100"
  cpt_scope:         "99213,99214"
  source:            "ai_generated"
  status:            "active"
