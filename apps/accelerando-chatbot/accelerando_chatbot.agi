// ─────────────────────────────────────────────────────────────────────────────
// TESTS
// ─────────────────────────────────────────────────────────────────────────────

TEST session_create {
  GIVEN   ConversationSession { customer_email: "test@example.com", session_token: "test-001", tenant_id: "test" }
  EXPECT  create -> session_token IS NOT NULL
  EXPECT  create -> status == "active"
  EXPECT  create -> resolved == false
}

TEST knowledge_entry_create {
  GIVEN   KnowledgeEntry { category: "billing", question: "Test Q", answer: "Test A", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  create -> active == true
}

TEST escalation_record_create {
  GIVEN   EscalationRecord { session_id: "test-001", reason: "High frustration", trigger_rule: "escalate_high_frustration", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  get_by_id -> reason == "High frustration"
  EXPECT  get_by_id -> trigger_rule == "escalate_high_frustration"
}
