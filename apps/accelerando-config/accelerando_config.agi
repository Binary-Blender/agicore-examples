// ─────────────────────────────────────────────────────────────────────────────
// TESTS
// ─────────────────────────────────────────────────────────────────────────────

TEST template_library_loaded {
  GIVEN   ConfigurationTemplate { config_id: "test_template", name: "Test", industry: "test", size_tier: "startup", modules_to_add: "core", description: "Test template", tenant_id: "test" }
  EXPECT  create -> config_id IS NOT NULL
  EXPECT  create -> active == true
  EXPECT  create -> usage_count == 0
}

TEST configuration_change_logged {
  GIVEN   ConfigurationChange { change_type: "template_applied", operator_id: "ops-001", triggered_by: "intake_flow", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  get_by_id -> change_type == "template_applied"
}

TEST compliance_check_create {
  GIVEN   ComplianceCheck { framework: "sox", tenant_id: "test" }
  EXPECT  create -> id IS NOT NULL
  EXPECT  create -> status == "pending"
  EXPECT  create -> gaps_found == 0
}
