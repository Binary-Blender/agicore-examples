// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOWS
// ─────────────────────────────────────────────────────────────────────────────

WORKFLOW run_kaizen_event {
  IDEMPOTENT false
  STEP charter            { ACTION GenerateKaizenCharter         ON_FAIL abort }
  STEP baseline_metrics   { ACTION LogPIEvent                    ON_FAIL abort }
  STEP waste_walk         { ACTION ConductWasteWalk              ON_FAIL skip  }
  STEP run_event          { ACTION LogPIEvent                    ON_FAIL abort }
  STEP score_results      { ACTION CalculateProjectROI           ON_FAIL skip  }
  STEP assign_actions     { ACTION LogPIEvent                    ON_FAIL abort }
  STEP generate_swi       { ACTION GenerateStandardWork          ON_FAIL skip  }
  STEP generate_control   { ACTION GenerateControlPlan           ON_FAIL skip  }
  STEP schedule_checks    { ACTION CreateSustainabilityChecks    ON_FAIL abort }
  STEP log                { ACTION LogPIEvent                    ON_FAIL skip  }
}

WORKFLOW dmaic_define {
  IDEMPOTENT false
  STEP charter            { ACTION GenerateKaizenCharter         ON_FAIL abort }
  STEP scope              { ACTION LogPIEvent                    ON_FAIL abort }
  STEP sipoc              { ACTION LogPIEvent                    ON_FAIL skip  }
  STEP tollgate           { ACTION LogPIEvent                    ON_FAIL abort }
}

WORKFLOW dmaic_measure {
  IDEMPOTENT false
  STEP baseline           { ACTION RunSPCAnalysis                ON_FAIL abort }
  STEP capability         { ACTION RunSPCAnalysis                ON_FAIL abort }
  STEP msa                { ACTION LogPIEvent                    ON_FAIL skip  }
  STEP tollgate           { ACTION LogPIEvent                    ON_FAIL abort }
}

WORKFLOW dmaic_control {
  IDEMPOTENT false
  STEP control_plan       { ACTION GenerateControlPlan           ON_FAIL abort }
  STEP standard_work      { ACTION GenerateStandardWork          ON_FAIL abort }
  STEP spc_setup          { ACTION RunSPCAnalysis                ON_FAIL skip  }
  STEP schedule_checks    { ACTION CreateSustainabilityChecks    ON_FAIL abort }
  STEP roi_calc           { ACTION CalculateProjectROI           ON_FAIL skip  }
  STEP tollgate           { ACTION LogPIEvent                    ON_FAIL abort }
}

WORKFLOW sustainability_check {
  IDEMPOTENT true
  STEP detect_drift       { ACTION DetectMetricDrift             ON_FAIL abort }
  STEP spc_analysis       { ACTION RunSPCAnalysis                ON_FAIL skip  }
  STEP audit_control_plan { ACTION LogPIEvent                    ON_FAIL skip  }
  STEP update_status      { ACTION LogPIEvent                    ON_FAIL abort }
  STEP replicate_if_ready { ACTION EmitReplicationPacket         ON_FAIL skip  }
  STEP log                { ACTION LogPIEvent                    ON_FAIL skip  }
}

WORKFLOW five_s_audit {
  IDEMPOTENT true
  STEP conduct_survey     { ACTION ScoreFiveSSurvey              ON_FAIL abort }
  STEP assign_actions     { ACTION SuggestImprovementOpportunities ON_FAIL skip }
  STEP log                { ACTION LogPIEvent                    ON_FAIL skip  }
}

WORKFLOW waste_walk_and_prioritize {
  IDEMPOTENT true
  STEP conduct_walk       { ACTION ConductWasteWalk              ON_FAIL abort }
  STEP suggest_projects   { ACTION SuggestImprovementOpportunities ON_FAIL abort }
  STEP log                { ACTION LogPIEvent                    ON_FAIL skip  }
}

WORKFLOW capture_and_replicate {
  IDEMPOTENT false
  STEP lessons_learned    { ACTION GenerateLessonsLearned        ON_FAIL abort }
  STEP roi_final          { ACTION CalculateProjectROI           ON_FAIL skip  }
  STEP emit_replication   { ACTION EmitReplicationPacket         ON_FAIL skip  }
  STEP log                { ACTION LogPIEvent                    ON_FAIL skip  }
}

// ─────────────────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────────────────

VIEW PICoEDashboard {
  ENTITY   ImprovementProject
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW KaizenTracker {
  ENTITY   KaizenEvent
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW SustainabilityMonitor {
  ENTITY   SustainabilityCheck
  LAYOUT   table
  ACTIONS  read, edit
}

VIEW ValueStreamHealth {
  ENTITY   ValueStream
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW MetricsDashboard {
  ENTITY   MetricReading
  LAYOUT   table
  ACTIONS  create, read
}

VIEW WasteObservationLog {
  ENTITY   WasteObservation
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW ActionItemBoard {
  ENTITY   ActionItem
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW BeltRegistry {
  ENTITY   BeltCertification
  LAYOUT   table
  ACTIONS  create, read, edit
}

VIEW LessonsLearnedLibrary {
  ENTITY   LessonsLearned
  LAYOUT   table
  ACTIONS  read
}

// ─────────────────────────────────────────────────────────────────────────────
// PREFERENCES
// ─────────────────────────────────────────────────────────────────────────────

PREFERENCE sustainability_check_30d_enabled      { DEFAULT true   TYPE bool   }
PREFERENCE sustainability_check_60d_enabled      { DEFAULT true   TYPE bool   }
PREFERENCE sustainability_check_90d_enabled      { DEFAULT true   TYPE bool   }
PREFERENCE sustainability_check_6m_enabled       { DEFAULT true   TYPE bool   }
PREFERENCE sustainability_check_annual_enabled   { DEFAULT true   TYPE bool   }
PREFERENCE regression_minor_threshold_pct        { DEFAULT 15     TYPE number }
PREFERENCE regression_major_threshold_pct        { DEFAULT 50     TYPE number }
PREFERENCE replication_roi_threshold_dollars     { DEFAULT 10000  TYPE number }
PREFERENCE control_audit_default_days            { DEFAULT 30     TYPE number }
PREFERENCE five_s_target_score                   { DEFAULT 80     TYPE number }
PREFERENCE oee_world_class_threshold             { DEFAULT 85     TYPE number }
PREFERENCE action_item_overdue_escalation_days   { DEFAULT 7      TYPE number }

// ─────────────────────────────────────────────────────────────────────────────
// SEED DATA — TPS and Six Sigma Tool Library
// ─────────────────────────────────────────────────────────────────────────────

SEED WasteObservation [
  { waste_type: "transportation", description: "SEED: Material moved between non-adjacent workstations", estimated_impact: "medium", observed_by: "system" },
  { waste_type: "inventory",      description: "SEED: WIP accumulation between operations exceeds kanban limit", estimated_impact: "high",   observed_by: "system" },
  { waste_type: "motion",         description: "SEED: Operator reaches above shoulder or below knee for frequent items", estimated_impact: "medium", observed_by: "system" },
  { waste_type: "waiting",        description: "SEED: Machine waits for operator — operator waits for machine", estimated_impact: "high",   observed_by: "system" },
  { waste_type: "overproduction", description: "SEED: Producing to forecast instead of to customer pull signal", estimated_impact: "high",   observed_by: "system" },
  { waste_type: "over_processing", description: "SEED: Tighter tolerance held than customer specification requires", estimated_impact: "medium", observed_by: "system" },
  { waste_type: "defects",        description: "SEED: Rework station exists — rework is designed into the process", estimated_impact: "critical", observed_by: "system" },
  { waste_type: "skills",         description: "SEED: Operators performing non-value-add tasks their skills exceed", estimated_impact: "medium", observed_by: "system" }
]
