ACTION RunSPCAnalysis {
  INPUT  metric_id: string, readings: string
  OUTPUT out_of_control: bool, signals: string, cpk: float
  IMPL {
    // Calculate control limits from readings if not already set:
    //   UCL = mean + 3 * std_dev
    //   LCL = mean - 3 * std_dev
