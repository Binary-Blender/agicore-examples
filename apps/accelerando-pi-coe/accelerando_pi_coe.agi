ACTION DetectMetricDrift {
  INPUT  kaizen_id: string, metric_id: string
  OUTPUT regression_detected: bool, severity: string, regression_pct: float
  IMPL {
    // Load last 30 MetricReadings for this metric
    // Compare rolling 7-day average to:
    //   target_value (post-event improvement target)
    //   baseline_value (pre-event baseline)
