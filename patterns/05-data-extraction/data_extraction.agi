// data_extraction.agi
// Data Extraction — Agicore DSL Example 05
//
// Extract structured data from unstructured text (contracts, invoices, emails,
// receipts) using typed ENTITY schemas as the extraction target.
// A three-stage PIPELINE: classify → extract → validate.
// If the extracted value doesn't match the schema, it fails cleanly with a
// typed error — not a hallucinated field that silently corrupts your database.
//
// Declarations: APP, TYPE, ENTITY, AI_SERVICE, ACTION, PIPELINE, VIEW, LOG, TEST

APP data_extraction {
  TITLE  "Data Extraction"
  WINDOW 1200x800 frameless
  DB     data_extraction.db
  THEME  dark
}

// ===================================================================
// AI SERVICE
// ===================================================================

AI_SERVICE {
  PROVIDERS  anthropic
  KEYS_FILE  "%APPDATA%/DataExtraction/api-keys.json"
  DEFAULT    anthropic
  STREAMING  false
  MODELS {
    anthropic  "claude-sonnet-4-20250514"  LABEL "Claude Sonnet 4"  DEFAULT
    anthropic  "claude-haiku-4-5-20251001" LABEL "Claude Haiku 4.5"
  }
}

// ===================================================================
// TYPE ALIASES
// ===================================================================

TYPE DocumentKind     = "contract" | "invoice" | "email" | "receipt" | "other"
TYPE ExtractionStatus = "pending" | "complete" | "failed" | "needs_review"
TYPE ConfidenceLevel  = "high" | "medium" | "low" | "none"

// ===================================================================
// DATA MODELS
// ===================================================================

ENTITY Document {
  kind:   string = "other"
  source: string REQUIRED
  raw:    string REQUIRED
  status: string = "pending"
  TIMESTAMPS
}

ENTITY ExtractionSchema {
  name:        string REQUIRED
  document_kind: string REQUIRED
  fields:      json REQUIRED
  TIMESTAMPS
}

ENTITY ExtractedField {
  field_name:       string REQUIRED
  field_value:      string
  confidence:       number = 0
  confidence_level: string = "none"
  BELONGS_TO Document
  TIMESTAMPS
}

ENTITY ExtractionRun {
  schema_name:   string REQUIRED
  model:         string REQUIRED
  fields_found:  number = 0
  fields_total:  number = 0
  passed:        bool = false
  error:         string
  BELONGS_TO Document
  TIMESTAMPS
}

// ===================================================================
// AI ACTIONS
// ===================================================================

// Stage 1: classify what kind of document this is
ACTION classify_document {
  INPUT  document_id: string, raw: string
  OUTPUT kind: string, confidence: number, reasoning: string
  AI     """Classify this document into one of these categories: contract, invoice, email, receipt, other.

Document text:
{{raw}}

Return a JSON object with:
- "kind": the classification (contract | invoice | email | receipt | other)
- "confidence": 0.0-1.0 how confident you are
- "reasoning": one sentence explaining why you classified it this way"""
  STREAM false
}

// Stage 2: extract structured fields from the document
ACTION extract_fields {
  INPUT  document_id: string, raw: string, kind: string, schema: json
  OUTPUT fields: json, fields_found: number, fields_total: number
  AI     """Extract structured data from this {{kind}} document.

Target fields to extract (with types):
{{schema}}

Document text:
{{raw}}

For each field in the schema, extract its value from the document. If a field is not present, set its value to null.

Return a JSON object with:
- "fields": object where each key is a field name and value is {value: string|null, confidence: 0.0-1.0, confidence_level: "high"|"medium"|"low"|"none"}
- "fields_found": count of fields where value is not null
- "fields_total": total fields in the schema

IMPORTANT: Only extract values that are explicitly stated in the document. Do not infer or estimate values."""
  STREAM false
}

// Stage 3: custom validation — in a real implementation, fill in Rust
ACTION validate_extraction {
  INPUT  document_id: string, fields: json, schema: json
  OUTPUT valid: bool, errors: json, warnings: json
  IMPL   "validate_extraction"
}

// ===================================================================
// PIPELINE — three stages, classified before extraction
// ===================================================================

PIPELINE extraction_pipeline {
  DESCRIPTION "Three-stage document extraction: classify → extract → validate. Idempotent — safe to re-run."
  IDEMPOTENT  true

  ROW classify {
    classifier: ai_action {
      action "classify_document"
      output "kind"
    }
  }

  ROW extract {
    extractor: ai_action {
      action  "extract_fields"
      input   "classify.kind"
      output  "fields"
    }
  }

  ROW validate {
    validator: custom {
      action "validate_extraction"
      input  "extract.fields"
    }
  }

  CONNECTION classify.kind   -> extract.kind
  CONNECTION extract.fields  -> validate.fields
}

// ===================================================================
// SEED DATA — starter extraction schemas
// ===================================================================

SEED ExtractionSchema {
  name: "Invoice Standard"
  document_kind: "invoice"
}

SEED ExtractionSchema {
  name: "Contract Parties"
  document_kind: "contract"
}

// ===================================================================
// VIEWS
// ===================================================================

VIEW DocumentList {
  ENTITY  Document
  LAYOUT  table
  ACTIONS create, delete
  FIELDS  kind, status, source, created_at
  TITLE   "Documents"
}

VIEW SchemaList {
  ENTITY  ExtractionSchema
  LAYOUT  table
  ACTIONS create, delete
  FIELDS  name, document_kind, created_at
  TITLE   "Extraction Schemas"
}

VIEW ExtractedFieldList {
  ENTITY  ExtractedField
  LAYOUT  table
  FIELDS  field_name, field_value, confidence_level, created_at
  TITLE   "Extracted Fields"
}

VIEW RunHistory {
  ENTITY  ExtractionRun
  LAYOUT  table
  FIELDS  schema_name, model, fields_found, fields_total, passed, created_at
  TITLE   "Extraction Runs"
}

// ===================================================================
// LOGGING
// ===================================================================

LOG {
  LEVEL   info
  TARGET  file
  PATH    "logs/data_extraction.log"
  ROTATE  "weekly"
}

// ===================================================================
// TESTS
// ===================================================================

TEST document_created {
  GIVEN Document { kind: "invoice", source: "email-attachment-jan.pdf", raw: "Invoice #1234  Date: 2026-01-15  Amount Due: $2,500.00  Vendor: Acme Corp" }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> status == "pending"
  EXPECT create -> kind == "invoice"
}

TEST extracted_field_belongs_to_document {
  GIVEN Document { kind: "contract", source: "nda-2026.pdf", raw: "This Non-Disclosure Agreement is entered into on January 1, 2026 between Acme Corp and Globex Inc." }
  GIVEN ExtractedField { field_name: "effective_date", field_value: "2026-01-01", confidence: 92, confidence_level: "high", BELONGS_TO Document }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> field_name == "effective_date"
  EXPECT create -> confidence > 80
}

TEST schema_created {
  GIVEN ExtractionSchema { name: "Receipt Items", document_kind: "receipt" }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> document_kind == "receipt"
}
