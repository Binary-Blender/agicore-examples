// automated_qa.agi
// Automated QA — Agicore DSL Example 04
//
// AI-powered quality assurance system. Evaluates generated content against
// defined criteria using structured rubrics, SPC-tracked pass/fail rates,
// and a revision workflow that routes low-quality output back for improvement.
// The QC declaration applies the same statistical process control Toyota uses
// in manufacturing — to AI output quality.
//
// Declarations: APP, TYPE, ENTITY, AI_SERVICE, QC, ACTION, WORKFLOW, VIEW, LOG, TEST

APP automated_qa {
  TITLE  "Automated QA"
  WINDOW 1300x850 frameless
  DB     automated_qa.db
  THEME  dark
}

// ===================================================================
// AI SERVICE — two models: fast for review, capable for revision
// ===================================================================

AI_SERVICE {
  PROVIDERS  anthropic, openai
  KEYS_FILE  "%APPDATA%/AutomatedQA/api-keys.json"
  DEFAULT    anthropic
  STREAMING  true
  MODELS {
    anthropic  "claude-sonnet-4-20250514"  LABEL "Claude Sonnet 4"  DEFAULT
    openai     "gpt-4o-mini"               LABEL "GPT-4o Mini"      DEFAULT
  }
}

// ===================================================================
// TYPE ALIASES
// ===================================================================

TYPE QAStatus      = "pending" | "pass" | "fail" | "revised" | "approved"
TYPE SeverityLevel = "minor" | "major" | "critical" | "blocker"

// ===================================================================
// QUALITY CONTROL — SPC tracking for AI output pass rates
// ===================================================================

QC output_quality {
  YOUNG_THRESHOLD     30
  MATURING_THRESHOLD  150
  YOUNG_PASS_RATE     0.80
  MATURE_PASS_RATE    0.92
  MATURING_SAMPLE     0.40
  MATURE_SAMPLE       0.10
}

// ===================================================================
// DATA MODELS
// ===================================================================

ENTITY Artifact {
  title:    string REQUIRED
  content:  string REQUIRED
  category: string = "general"
  status:   string = "pending"
  revision: number = 0
  TIMESTAMPS
}

ENTITY QARubric {
  name:        string REQUIRED
  description: string REQUIRED
  criteria:    json = []
  pass_threshold: number = 75
  TIMESTAMPS
}

ENTITY QAResult {
  passed:         bool REQUIRED
  overall_score:  number REQUIRED
  dimension_scores: json = []
  issues:         json = []
  revision_notes: string
  reviewer_model: string REQUIRED
  BELONGS_TO Artifact
  TIMESTAMPS
}

ENTITY RevisionNote {
  dimension:  string REQUIRED
  severity:   string REQUIRED
  issue:      string REQUIRED
  suggestion: string REQUIRED
  BELONGS_TO QAResult
  TIMESTAMPS
}

// ===================================================================
// AI ACTIONS
// ===================================================================

// Review an artifact against a rubric — produces structured QA result
ACTION review_artifact {
  INPUT  artifact_id: string, title: string, content: string, category: string, rubric: json
  OUTPUT passed: bool, overall_score: number, dimension_scores: json, issues: json, revision_notes: string
  AI     """You are a quality assurance reviewer evaluating a content artifact.

Artifact Title: {{title}}
Category: {{category}}

Content to review:
{{content}}

Evaluation rubric:
{{rubric}}

Evaluate the artifact against each rubric criterion. For each criterion, assign a score 0-100 and identify specific issues.

Return a JSON object with:
- "passed": true if overall_score >= rubric.pass_threshold, false otherwise
- "overall_score": weighted average across all criteria (0-100)
- "dimension_scores": array of {criterion, score, rationale} objects
- "issues": array of {dimension, severity, issue, suggestion} where severity is "minor"|"major"|"critical"|"blocker"
- "revision_notes": one paragraph summarizing what must change for this to pass (empty string if passed)"""
  STREAM false
}

// Revise an artifact based on QA feedback
ACTION revise_artifact {
  INPUT  title: string, content: string, issues: json, revision_notes: string, category: string
  OUTPUT content: string, changes_made: json
  AI     """You are revising a content artifact based on QA reviewer feedback.

Artifact Title: {{title}}
Category: {{category}}

Original content:
{{content}}

QA issues to address:
{{issues}}

Reviewer notes:
{{revision_notes}}

Rewrite the artifact to address ALL issues, especially any marked major, critical, or blocker. Preserve everything that was good. Do not add padding or filler — only improve.

Return a JSON object with:
- "content": the complete revised artifact text
- "changes_made": array of one-sentence descriptions of what changed"""
  STREAM true
}

// Final approval gate — used after revision
ACTION approve_artifact {
  INPUT  title: string, original_content: string, revised_content: string, original_issues: json
  OUTPUT approved: bool, remaining_issues: json, approval_note: string
  AI     """You are doing a final approval check on a revised artifact.

Title: {{title}}

Original issues that were flagged:
{{original_issues}}

Revised content:
{{revised_content}}

Check whether all critical and blocker issues from the original review have been resolved. Minor issues can remain if they do not affect the artifact's core quality.

Return a JSON object with:
- "approved": true if all critical/blocker issues resolved
- "remaining_issues": array of any still-unresolved issues (should be empty for approval)
- "approval_note": one sentence explaining the approval or rejection decision"""
  STREAM false
}

// ===================================================================
// WORKFLOW — review → revise if failed → approve
// ===================================================================

WORKFLOW qa_workflow {
  STEP review {
    ACTION  review_artifact
    ON_FAIL stop
  }
  STEP revise {
    ACTION  revise_artifact
    ON_FAIL skip
  }
  STEP approve {
    ACTION  approve_artifact
    ON_FAIL stop
  }
}

// ===================================================================
// VIEWS
// ===================================================================

VIEW ArtifactList {
  ENTITY  Artifact
  LAYOUT  table
  ACTIONS create, delete
  FIELDS  title, category, status, revision, created_at
  TITLE   "Artifacts"
}

VIEW QARubricList {
  ENTITY  QARubric
  LAYOUT  table
  ACTIONS create, delete
  FIELDS  name, pass_threshold, created_at
  TITLE   "QA Rubrics"
}

VIEW QAResultList {
  ENTITY  QAResult
  LAYOUT  table
  FIELDS  passed, overall_score, reviewer_model, created_at
  TITLE   "QA Results"
}

VIEW ArtifactEditor {
  ENTITY  Artifact
  LAYOUT  document_editor
  TITLE   "Artifact Editor"
}

// ===================================================================
// LOGGING
// ===================================================================

LOG {
  LEVEL   info
  TARGET  file
  PATH    "logs/automated_qa.log"
  ROTATE  "weekly"
}

// ===================================================================
// SEED DATA — a starter rubric so the app is useful on first launch
// ===================================================================

SEED QARubric {
  name: "General Content Quality"
  description: "Standard rubric for evaluating AI-generated content"
  pass_threshold: 75
}

// ===================================================================
// TESTS
// ===================================================================

TEST artifact_created {
  GIVEN Artifact { title: "Product Launch Announcement", content: "We are excited to announce...", category: "marketing" }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> status == "pending"
  EXPECT create -> revision == 0
}

TEST qa_result_belongs_to_artifact {
  GIVEN Artifact { title: "Technical Specification v1", content: "This document describes...", category: "technical" }
  GIVEN QAResult { passed: false, overall_score: 62, reviewer_model: "claude-sonnet-4-20250514", revision_notes: "Missing error handling section.", BELONGS_TO Artifact }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> passed == false
  EXPECT create -> overall_score == 62
}

TEST rubric_created {
  GIVEN QARubric { name: "API Documentation", description: "Rubric for REST API documentation quality", pass_threshold: 80 }
  EXPECT create -> id IS NOT NULL
  EXPECT create -> pass_threshold == 80
}
